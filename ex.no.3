#include <stdio.h>

int q[10], front=-1, rear=-1;

void enqueue(int x){
    if(front==-1) front=0;
    q[++rear]=x;
}
void display(){
    for(int i=front;i<=rear;i++)
        printf("%d ",q[i]);
}

int main(){
    enqueue(1);
    enqueue(2);
    enqueue(3);
    printf("Ready Queue: ");
    display();
    return 0;
}
